{
  "expo": {
    "name": "MacroZone",
    "slug": "macrozone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "macrozone",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/icon.svg",
      "bundleIdentifier": "macrozone",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icon.png",
        "backgroundImage": "./assets/icon.png",
        "monochromeImage": "./assets/icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ope_yemi.macrozone"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icon.svg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1a1a2e",
          "android": {
            "image": "./assets/icon.svg",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "febccb6c-071d-4b64-80d8-1a6b4cf46b15"
      }
    },
    "owner": "ope_yemi"
  }
}
